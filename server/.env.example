# ── Database ──────────────────────────────────────────────────────────────────
# Local dev (docker-compose): both can be the same direct Postgres URL.
DATABASE_URL=postgresql://aurum:aurum_secret@localhost:5432/aurum_db
DIRECT_URL=postgresql://aurum:aurum_secret@localhost:5432/aurum_db

# ── Supabase (production on Vercel) ───────────────────────────────────────────
# Supabase dashboard → Project Settings → Database → Connection string.
# DATABASE_URL  = the "Transaction" pooler URL (port 6543). Append the pgbouncer
#                 flags exactly as shown:
#   DATABASE_URL=postgresql://postgres.xxxx:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
# DIRECT_URL    = the "Session" / direct URL (port 5432) — used only for migrations:
#   DIRECT_URL=postgresql://postgres.xxxx:PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres

JWT_SECRET=your_super_secret_jwt_key_change_in_production
# Your Vercel site URL in production, e.g. https://aurum.vercel.app (no trailing slash)
CLIENT_URL=http://localhost:5173
PORT=5000
NODE_ENV=development

# Protects the Vercel Cron endpoint (/api/cron/overdue). Set to any random string.
CRON_SECRET=

# ── Email notifications (optional — leave blank to disable) ───────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_gmail_app_password
